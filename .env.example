# K-Life × Stellar — Environment Variables
# Copy to .env and fill in your values
# Run `node src/setup.js` to auto-generate testnet wallets

STELLAR_NETWORK=testnet
HORIZON_URL=https://horizon-testnet.stellar.org

# Agent Stellar keypair (generated by setup.js)
AGENT_SECRET=your_stellar_secret_key_here
AGENT_NAME=My K-Life Agent

# K-Life vault address (receives insurance premiums)
VAULT_ADDRESS=your_vault_stellar_address_here

# Heartbeat config
HEARTBEAT_INTERVAL_MS=30000   # 30s for demo, 3600000 for production (1h)
HEARTBEAT_AMOUNT=0.001        # XLM per heartbeat (insurance micropayment)
DEATH_TIMEOUT_MS=90000        # 90s for demo, 86400000 for production (24h)

# x402 resurrection server
X402_PORT=3402
X402_PRICE=0.001              # XLM to unlock resurrection payload
